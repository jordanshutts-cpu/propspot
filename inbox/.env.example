# ── Database (shared with Prop Spot) ───────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/propspot

# ── JWT (must byte-match Prop Spot's JWT_SECRET) ───────────────────
JWT_SECRET=copy-from-propspot-os

# ── App URLs ───────────────────────────────────────────────────────
OS_URL=https://os.propspot.io
APP_URL=https://inbox.propspot.io
OS_INTERNAL_URL=http://propspot-os.railway.internal
HOLDINGS_URL=https://holdings.propspot.io
MAINTENANCE_URL=https://maintenance.propspot.io
FIELDCAM_URL=https://fieldcam.propspot.io
PULSE_URL=https://pulse.propspot.io

# ── Google OAuth (one client for the whole propspot platform) ──────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_OAUTH_REDIRECT below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=https://inbox.propspot.io/api/mailboxes/oauth/callback

# ── Cloudinary (same values FieldCam already uses) ─────────────────
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── Encryption key for OAuth refresh tokens at rest ────────────────
# Generate with: openssl rand -base64 32
INBOX_TOKEN_KEY=

# ── Sync cadence (seconds between Gmail history pulls per mailbox) ─
INBOX_SYNC_INTERVAL_SECONDS=60

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
