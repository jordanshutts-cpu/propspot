# ── Database (shared with Prop Spot) ───────────────────────────────
# Use Railway's reference variable syntax to share Prop Spot's Postgres:
#   ${{Postgres.DATABASE_URL}}   (referencing the Prop Spot project)
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Auth (MUST be byte-identical to Prop Spot's JWT_SECRET) ────────
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars

# ── App ────────────────────────────────────────────────────────────
APP_URL=https://holdings.propspot.io
PORT=3000

# ── Prop Spot (the OS) ─────────────────────────────────────────────
# Public URL — used by the frontend redirect on sign-out / missing token.
OS_URL=https://os.propspot.io

# Optional Railway-internal hostname for /api/me pass-through. Falls
# back to OS_URL when unset.
OS_INTERNAL_URL=http://propspot.railway.internal
