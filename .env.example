# ── Database (shared with Prop Spot — point this at Prop Spot's DB) ──
# Use Railway's reference variable syntax to share Prop Spot's Postgres:
#   ${{Postgres.DATABASE_URL}}  (from the Prop Spot project)
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Auth (MUST be byte-identical to Prop Spot's JWT_SECRET) ──────────
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars

# ── Cloudinary (photo storage; same account as Prop Spot) ────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── App ──────────────────────────────────────────────────────────────
APP_URL=https://fieldcam.railway.app
PORT=3000

# ── Sibling satellite (Maintenance) ─────────────────────────────────
# Public URL of the Maintenance satellite. Used by the camera page so
# /api/visits/:id/attach-photo callbacks can be CORS-validated.
MAINTENANCE_URL=https://maintenance.railway.app

# ── Prop Spot (the OS) ───────────────────────────────────────────────
# Public URL — used by the frontend redirect on sign-out / missing token.
OS_URL=https://os.propspot.io

# Optional Railway-internal hostname for /api/me pass-through. Falls
# back to OS_URL when unset.
OS_INTERNAL_URL=http://propspot.railway.internal

# ── Maps (frontend; non-secret, served via /api/config) ──────────────
GOOGLE_MAPS_API_KEY=
