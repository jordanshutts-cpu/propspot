# ── Database (shared with Prop Spot OS — Model A integration) ───
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Auth (MUST match the JWT_SECRET on Prop Spot OS) ────────────
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars

# ── Prop Spot OS endpoints ──────────────────────────────────────
OS_URL=https://os.propspot.io
# Optional: internal URL for service-to-service calls if your platform exposes it
OS_INTERNAL_URL=

# ── Cross-app navigation (so the unified sidebar can link out) ──
HOLDINGS_URL=https://holdings.propspot.io
MAINTENANCE_URL=https://maintenance.propspot.io
FIELDCAM_URL=https://fieldcam.propspot.io

# ── App ─────────────────────────────────────────────────────────
APP_URL=https://pulse.propspot.io
PORT=3000
