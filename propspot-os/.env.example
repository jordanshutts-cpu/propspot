# ── Database (Railway provides this automatically) ──────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Auth (MUST match the JWT_SECRET on every connected app) ─────
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars
JWT_EXPIRES_IN=30d

# ── Email Invites (Resend SMTP — see docs/operator/resend-setup.md) ──
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Prop Spot <invites@propspot.io>

# ── Cloudinary (photo storage; shared with FieldCam satellite) ──
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Maps (frontend; non-secret, served via /api/config) ─────────
GOOGLE_MAPS_API_KEY=

# ── App ─────────────────────────────────────────────────────────
APP_URL=https://your-os.railway.app
PORT=3000

# ── Bootstrap (used once on first deploy) ───────────────────────
# Email of the first owner. They get a signup-eligible row pre-seeded
# with full grants on every app. After signup, normal access control
# applies and this var is ignored.
BOOTSTRAP_OWNER_EMAIL=
