# ── Database (Railway provides this automatically) ──────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars
JWT_EXPIRES_IN=30d

# ── Cloudinary (free at cloudinary.com) ──────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email Invites (optional — Gmail example) ──────────────────────
# If not set, invite links are returned in the API response instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=FieldCam <you@gmail.com>

# ── App ───────────────────────────────────────────────────────────
# The public URL of your Railway deployment (no trailing slash)
APP_URL=https://your-app.railway.app
PORT=3000
