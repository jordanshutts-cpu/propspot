# Shared with Prop Spot — same Postgres, same JWT signing key.
DATABASE_URL=postgresql://user:pass@host:5432/propspot
JWT_SECRET=replace-with-the-same-value-as-prop-spot

# CORS allow-list for the browser. Comma-separated origins, or leave * in dev.
APP_URL=https://maintenance.railway.app,https://propspot.railway.app,https://fieldcam.railway.app

# Sibling apps. Used by the frontend for SSO deep-links and cross-app fetches.
PROPSPOT_URL=https://propspot.railway.app
FIELDCAM_URL=https://fieldcam.railway.app

# Google Maps Places API (optional — only used by admin.html if address lookup is enabled).
GOOGLE_MAPS_API_KEY=
